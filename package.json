{
  "name": "remote-job-search-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension that opens remote frontend, backend, and full stack job searches on Indeed, ZipRecruiter, Dice, Monster, and Glassdoor.",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:smoke": "node ./scripts/run-live-tests.mjs",
    "test:live": "npm run test:smoke --",
    "test:check": "npm run test:coverage && npm run typecheck && npm run build",
    "test:full": "npm run test:check && npm run test:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.19",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.25.10",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.5.207"
  }
}
